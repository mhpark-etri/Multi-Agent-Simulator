<?xml version="1.0"?>
<sdf version="1.7">
  <model name="guardrail_panel_slope_1m">
    <static>true</static>

    <!--
      Local frame:
        - Length along +X (1.00m)
        - Thin along +Y
        - Z up

      How to use on stairs:
        - Apply pitch at <include><pose>...</pose></include>
        - Example pitch: -0.523599 (=-30deg)
    -->

    <link name="guardrail_link">
      <pose>0 0 0 0 0 0</pose>

      <!-- ==========================
           COLLISION (lightweight)
           ========================== -->
      <collision name="col_top_rail">
        <pose>0 0 0.95 0 0 0</pose>
        <geometry><box><size>1.00 0.05 0.05</size></box></geometry>
      </collision>

      <collision name="col_bottom_rail">
        <pose>0 0 0.30 0 0 0</pose>
        <geometry><box><size>1.00 0.05 0.05</size></box></geometry>
      </collision>

      <collision name="col_post_left">
        <pose>-0.47 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
      </collision>

      <collision name="col_post_right">
        <pose>0.47 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
      </collision>

      <collision name="col_foot_left">
        <pose>-0.30 0 0.03 0 0 0</pose>
        <geometry><box><size>0.18 0.14 0.06</size></box></geometry>
      </collision>

      <collision name="col_foot_right">
        <pose>0.30 0 0.03 0 0 0</pose>
        <geometry><box><size>0.18 0.14 0.06</size></box></geometry>
      </collision>

      <!-- ==========================
           VISUAL (detailed)
           ========================== -->
      <visual name="vis_top_rail">
        <pose>0 0 0.95 0 0 0</pose>
        <geometry><box><size>1.00 0.05 0.05</size></box></geometry>
        <material>
          <ambient>0.06 0.06 0.06 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
          <specular>0.20 0.20 0.20 1</specular>
        </material>
      </visual>

      <visual name="vis_bottom_rail">
        <pose>0 0 0.30 0 0 0</pose>
        <geometry><box><size>1.00 0.05 0.05</size></box></geometry>
        <material>
          <ambient>0.06 0.06 0.06 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
          <specular>0.20 0.20 0.20 1</specular>
        </material>
      </visual>

      <visual name="vis_post_left">
        <pose>-0.47 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
        <material><diffuse>0.10 0.10 0.10 1</diffuse></material>
      </visual>

      <visual name="vis_post_right">
        <pose>0.47 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
        <material><diffuse>0.10 0.10 0.10 1</diffuse></material>
      </visual>

      <visual name="vis_foot_left">
        <pose>-0.30 0 0.03 0 0 0</pose>
        <geometry><box><size>0.18 0.14 0.06</size></box></geometry>
        <material><diffuse>0.08 0.08 0.08 1</diffuse></material>
      </visual>

      <visual name="vis_foot_right">
        <pose>0.30 0 0.03 0 0 0</pose>
        <geometry><box><size>0.18 0.14 0.06</size></box></geometry>
        <material><diffuse>0.08 0.08 0.08 1</diffuse></material>
      </visual>

      <!-- Vertical bars (visual only) -->
      <visual name="vis_bar_01"><pose>-0.36 0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry></visual>
      <visual name="vis_bar_02"><pose>-0.24 0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry></visual>
      <visual name="vis_bar_03"><pose>-0.12 0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry></visual>
      <visual name="vis_bar_04"><pose>0.00  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry></visual>
      <visual name="vis_bar_05"><pose>0.12  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry></visual>
      <visual name="vis_bar_06"><pose>0.24  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry></visual>
      <visual name="vis_bar_07"><pose>0.36  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry></visual>
      <visual name="vis_bar_08"><pose>0.48  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry></visual>

      <self_collide>false</self_collide>
      <enable_wind>false</enable_wind>
      <kinematic>false</kinematic>
    </link>
  </model>
</sdf>


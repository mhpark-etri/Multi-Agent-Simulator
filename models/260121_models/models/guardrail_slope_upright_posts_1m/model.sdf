<?xml version="1.0"?>
<sdf version="1.7">
  <model name="guardrail_slope_upright_posts_1m">
    <static>true</static>

    <!--
      Key idea:
        - Posts are upright: roll=0, pitch=0
        - Only the HANDRAIL (black bar) is sloped: pitch = +/- ANGLE_RAD

      Angle:
        - Default 30deg: 0.523599 rad
        - If stair goes DOWN along +X direction, use pitch = -ANGLE_RAD
        - If stair goes UP along +X direction, use pitch = +ANGLE_RAD
    -->

    <link name="guardrail_link">
      <pose>0 0 0 0 0 0</pose>

      <!-- ====== PARAMETERS (edit here) ====== -->
      <!-- NOTE: SDF has no variables, so just edit the numbers below -->
      <!-- ANGLE_RAD = 0.523599 (30deg). We'll use -0.523599 for "down" by default. -->

      <!-- ==========================
           COLLISION (lightweight)
           ========================== -->

      <!-- Upright posts collision (white posts) -->
      <collision name="col_post_left">
        <pose>-0.47 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
      </collision>
      <collision name="col_post_mid">
        <pose>0.00 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
      </collision>
      <collision name="col_post_right">
        <pose>0.47 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
      </collision>

      <!-- Feet pads collision -->
      <collision name="col_foot_left">
        <pose>-0.30 0 0.03 0 0 0</pose>
        <geometry><box><size>0.18 0.14 0.06</size></box></geometry>
      </collision>
      <collision name="col_foot_right">
        <pose>0.30 0 0.03 0 0 0</pose>
        <geometry><box><size>0.18 0.14 0.06</size></box></geometry>
      </collision>

      <!-- Sloped handrail collision (black bar only) -->
      <!-- DOWN along +X: pitch = -0.523599 -->
      <collision name="col_handrail_sloped">
        <pose>0 0 0.95 0 -0.523599 0</pose>
        <geometry>
          <box><size>1.00 0.05 0.05</size></box>
        </geometry>
        <surface>
          <friction>
            <ode><mu>1.2</mu><mu2>1.2</mu2></ode>
          </friction>
        </surface>
      </collision>

      <!-- Optional: sloped lower rail (원하면 켜고, 아니면 삭제해도 됨) -->
      <collision name="col_lowerrail_sloped">
        <pose>0 0 0.30 0 -0.523599 0</pose>
        <geometry>
          <box><size>1.00 0.04 0.04</size></box>
        </geometry>
      </collision>

      <!-- ==========================
           VISUAL
           ========================== -->

      <!-- White upright posts -->
      <visual name="vis_post_left">
        <pose>-0.47 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
        <material>
          <ambient>0.85 0.85 0.85 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
          <specular>0.10 0.10 0.10 1</specular>
        </material>
      </visual>

      <visual name="vis_post_mid">
        <pose>0.00 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
        <material>
          <ambient>0.85 0.85 0.85 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
          <specular>0.10 0.10 0.10 1</specular>
        </material>
      </visual>

      <visual name="vis_post_right">
        <pose>0.47 0 0.50 0 0 0</pose>
        <geometry><box><size>0.06 0.06 1.00</size></box></geometry>
        <material>
          <ambient>0.85 0.85 0.85 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
          <specular>0.10 0.10 0.10 1</specular>
        </material>
      </visual>

      <!-- Feet pads (dark gray) -->
      <visual name="vis_foot_left">
        <pose>-0.30 0 0.03 0 0 0</pose>
        <geometry><box><size>0.18 0.14 0.06</size></box></geometry>
        <material>
          <ambient>0.06 0.06 0.06 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>

      <visual name="vis_foot_right">
        <pose>0.30 0 0.03 0 0 0</pose>
        <geometry><box><size>0.18 0.14 0.06</size></box></geometry>
        <material>
          <ambient>0.06 0.06 0.06 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>

      <!-- Black sloped handrail (people grab this) -->
      <visual name="vis_handrail_sloped">
        <pose>0 0 0.95 0 -0.523599 0</pose>
        <geometry><box><size>1.00 0.05 0.05</size></box></geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
          <specular>0.25 0.25 0.25 1</specular>
        </material>
      </visual>

      <!-- Optional: black sloped lower rail -->
      <visual name="vis_lowerrail_sloped">
        <pose>0 0 0.30 0 -0.523599 0</pose>
        <geometry><box><size>1.00 0.04 0.04</size></box></geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
          <specular>0.25 0.25 0.25 1</specular>
        </material>
      </visual>

      <!-- Vertical thin bars between rails (keep upright) -->
      <visual name="vis_bar_01"><pose>-0.36 0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry><material><diffuse>0.90 0.90 0.90 1</diffuse></material></visual>
      <visual name="vis_bar_02"><pose>-0.24 0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry><material><diffuse>0.90 0.90 0.90 1</diffuse></material></visual>
      <visual name="vis_bar_03"><pose>-0.12 0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry><material><diffuse>0.90 0.90 0.90 1</diffuse></material></visual>
      <visual name="vis_bar_04"><pose>0.00  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry><material><diffuse>0.90 0.90 0.90 1</diffuse></material></visual>
      <visual name="vis_bar_05"><pose>0.12  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry><material><diffuse>0.90 0.90 0.90 1</diffuse></material></visual>
      <visual name="vis_bar_06"><pose>0.24  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry><material><diffuse>0.90 0.90 0.90 1</diffuse></material></visual>
      <visual name="vis_bar_07"><pose>0.36  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry><material><diffuse>0.90 0.90 0.90 1</diffuse></material></visual>
      <visual name="vis_bar_08"><pose>0.48  0 0.55 0 0 0</pose><geometry><box><size>0.015 0.03 0.80</size></box></geometry><material><diffuse>0.90 0.90 0.90 1</diffuse></material></visual>

      <self_collide>false</self_collide>
      <enable_wind>false</enable_wind>
      <kinematic>false</kinematic>
    </link>
  </model>
</sdf>


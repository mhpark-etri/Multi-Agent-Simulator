<?xml version="1.0"?>
<sdf version="1.7">
  <model name="gray_brick_pile">
    <static>true</static>
    <pose>0 0 0 0 0 0</pose>

    <link name="brick_pile_link">

      <!-- =================
           Collision (전체 더미)
           ================= -->
      <collision name="col_pile">
